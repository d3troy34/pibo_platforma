# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy projects can temporarily use SUPABASE_SERVICE_ROLE_KEY instead.

# Bunny.net Stream (the browser only needs the public library ID)
NEXT_PUBLIC_BUNNY_STREAM_LIBRARY_ID=your-library-id

# Resend
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Pibo <no-reply@mipibo.com>

# Purchase webhook (shared secret with mipibo.com)
WEBHOOK_SECRET=your-webhook-secret-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
